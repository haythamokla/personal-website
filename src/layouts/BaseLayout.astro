---
import '../styles/global.css';
import { absoluteUrl, defaultLocale, getLocaleFromPath, getTranslations, localizedPath, locales, navItems, pathWithBase, removeLocaleFromPath, site } from '../lib/site';

type Breadcrumb = {
	name: string;
	url: string;
};

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	canonical?: string;
	breadcrumbs?: Breadcrumb[];
	noindex?: boolean;
	immersive?: boolean;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = site.title,
	description = site.description,
	image = '/og-image.jpg',
	type = 'website',
	canonical = Astro.url.pathname,
	breadcrumbs = [],
	noindex = false,
	immersive = false,
	structuredData,
} = Astro.props;

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const localeMeta = locales[locale] ?? locales[defaultLocale];
const t = getTranslations(locale);
const cleanCurrentPath = removeLocaleFromPath(currentPath);
const canonicalUrl = absoluteUrl(canonical);
const imageUrl = image.startsWith('http') ? image : absoluteUrl(image);
const pageTitle = title === site.title || title.includes(site.name) ? title : `${title} | ${site.name}`;

const baseSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: site.name,
	url: absoluteUrl('/'),
	jobTitle: 'Photographer and Visual Storyteller',
	email: site.email,
	address: {
		'@type': 'PostalAddress',
		addressLocality: site.location,
	},
	sameAs: site.socials.map((social) => social.href),
};

const breadcrumbSchema =
	breadcrumbs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: breadcrumbs.map((crumb, index) => ({
					'@type': 'ListItem',
					position: index + 1,
					name: crumb.name,
					item: absoluteUrl(crumb.url),
				})),
			}
		: undefined;

const jsonLd = [baseSchema, breadcrumbSchema, ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [])].filter(Boolean);
---

<!doctype html>
<html lang={locale} dir={localeMeta.dir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href={pathWithBase('/favicon.svg')} />
		<link rel="icon" href={pathWithBase('/favicon.ico')} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{
			Object.keys(locales).map((lang) => (
				<link rel="alternate" hreflang={lang} href={absoluteUrl(localizedPath(currentPath, lang as keyof typeof locales))} />
			))
		}
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		</head>
		<body>
			<a class="skip-link" href="#content">{t.skip}</a>
			<header class="site-header" aria-label="Primary navigation">
				<a class="brand" href={localizedPath('/', locale)} aria-label={`${site.name} home`}>
					<span>{site.name}</span>
				</a>
				<nav class="nav-links">
					{
						navItems.map((item) => (
							<a href={localizedPath(item.href, locale)} aria-current={cleanCurrentPath === item.href ? 'page' : undefined}>
								{t.nav[item.key]}
							</a>
						))
					}
				</nav>
				<nav class="locale-switcher" aria-label={t.languageOptions}>
					{
						Object.entries(locales).map(([code, value]) => (
						<a href={localizedPath(currentPath, code as keyof typeof locales)} aria-label={value.label} class={code === locale ? 'active' : undefined} aria-current={code === locale ? 'true' : undefined}>
								{code.toUpperCase()}
							</a>
						))
					}
				</nav>
			</header>
		<main id="content">
			<slot />
		</main>
		{
			!immersive && (
				<footer class="site-footer">
					<div>
						<a class="footer-brand" href={localizedPath('/', locale)}>{site.name}</a>
						<p>{t.footerText}</p>
					</div>
					<nav aria-label={t.footerNav}>
						{navItems.map((item) => <a href={localizedPath(item.href, locale)}>{t.nav[item.key]}</a>)}
					</nav>
					<nav aria-label={t.socialLinks}>
						{site.socials.map((social) => <a href={social.href} rel="noreferrer">{social.label}</a>)}
					</nav>
				</footer>
			)
		}
	</body>
</html>
