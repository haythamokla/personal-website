---
import type { CollectionEntry } from 'astro:content';
import { getProjectText } from '../lib/copy';
import { getLocaleFromPath, imageSrc, pathWithBase, type Locale } from '../lib/site';

interface Props {
	project: CollectionEntry<'portfolio'>;
	priority?: boolean;
	hrefPrefix?: string;
	locale?: Locale;
}

const { project, priority = false, hrefPrefix = '', locale = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const projectHref = pathWithBase(`${hrefPrefix}/portfolio/${project.id}/`);
const projectText = getProjectText(project.id, locale);
---

<article class="project-card">
	<a class="image-frame" href={projectHref} aria-label={projectText.title}>
		<img
			src={imageSrc(project.data.cover.src)}
			width={project.data.cover.width}
			height={project.data.cover.height}
			alt={project.data.cover.alt}
			sizes="(min-width: 780px) 33vw, 100vw"
			loading={priority ? 'eager' : 'lazy'}
			decoding="async"
		/>
	</a>
	<div class="card">
		<h3><a href={projectHref}>{projectText.title}</a></h3>
		<p class="muted">{projectText.description}</p>
	</div>
</article>

<style>
	.project-card {
		display: grid;
		gap: 1rem;
	}

	.image-frame {
		aspect-ratio: 4 / 5;
	}

	.project-card:nth-child(2) .image-frame {
		aspect-ratio: 1 / 1.25;
	}
</style>
