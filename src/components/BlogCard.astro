---
import type { CollectionEntry } from 'astro:content';
import { getCopy, getPostText } from '../lib/copy';
import { getLocaleFromPath, imageSrc, pathWithBase, readingTime, type Locale } from '../lib/site';

interface Props {
	post: CollectionEntry<'blog'>;
	hrefPrefix?: string;
	locale?: Locale;
}

const { post, hrefPrefix = '', locale = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const minutes = readingTime(post.body ?? '');
const postHref = pathWithBase(`${hrefPrefix}/blog/${post.id}/`);
const postText = getPostText(post.id, locale);
const copy = getCopy(locale);
---

<article class="blog-card">
	<a class="image-frame" href={postHref} aria-label={postText.title}>
		<img
			src={imageSrc(post.data.cover.src)}
			width={post.data.cover.width}
			height={post.data.cover.height}
			alt={post.data.cover.alt}
			loading="lazy"
			decoding="async"
		/>
	</a>
	<div class="card">
		<div class="meta">
			<time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
			<span>{minutes} {copy.common.reading}</span>
		</div>
		<h3><a href={postHref}>{postText.title}</a></h3>
		<p class="muted">{postText.description}</p>
	</div>
</article>

<style>
	.blog-card {
		display: grid;
		gap: 1rem;
	}

	.image-frame {
		aspect-ratio: 16 / 11;
	}
</style>
