---
import { pathWithBase } from '../lib/site';

interface Crumb {
	name: string;
	url: string;
}

interface Props {
	items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs container" aria-label="Breadcrumb">
	{
		items.map((item, index) => (
			<>
				{index > 0 && <span aria-hidden="true">/</span>}
				{index === items.length - 1 ? <span aria-current="page">{item.name}</span> : <a href={pathWithBase(item.url)}>{item.name}</a>}
			</>
		))
	}
</nav>
