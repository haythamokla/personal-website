---
interface Props {
	eyebrow: string;
	title: string;
	text: string;
}

const { eyebrow, title, text } = Astro.props;
---

<section class="page-intro container">
	<p class="eyebrow">{eyebrow}</p>
	<h1>{title}</h1>
	<p class="lead">{text}</p>
</section>

<style>
	.page-intro {
		display: grid;
		gap: 1.2rem;
		padding: 8rem 0 clamp(3rem, 7vw, 6rem);
	}

	.page-intro h1 {
		max-width: 10ch;
	}
</style>
