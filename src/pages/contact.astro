---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageIntro from '../components/PageIntro.astro';
import { getCopy } from '../lib/copy';
import { site } from '../lib/site';

const copy = getCopy('en');
const breadcrumbs = [
	{ name: copy.common.home, url: '/' },
	{ name: copy.contact.title, url: '/contact/' },
];
---

<BaseLayout
	title={copy.contact.title}
	description={copy.contact.description}
	canonical="/contact/"
	breadcrumbs={breadcrumbs}
>
	<Breadcrumbs items={breadcrumbs} />
	<PageIntro eyebrow={copy.contact.eyebrow} title={copy.contact.heading} text={copy.contact.text} />

	<section class="container contact-layout">
		<form class="contact-form" aria-label="Contact form placeholder">
			<label>
				<span>{copy.common.name}</span>
				<input type="text" name="name" autocomplete="name" placeholder={copy.contact.namePlaceholder} />
			</label>
			<label>
				<span>{copy.common.email}</span>
				<input type="email" name="email" autocomplete="email" placeholder={copy.contact.emailPlaceholder} />
			</label>
			<label>
				<span>{copy.common.projectType}</span>
				<select name="project">
					{copy.contact.projectOptions.map((option) => <option>{option}</option>)}
				</select>
			</label>
			<label>
				<span>{copy.common.message}</span>
				<textarea name="message" rows="7" placeholder={copy.contact.messagePlaceholder}></textarea>
			</label>
			<button class="button" type="button">{copy.common.formPlaceholder}</button>
		</form>

		<aside class="contact-panel">
			<div>
				<p class="eyebrow">{copy.common.direct}</p>
				<a href={`mailto:${site.email}`}>{site.email}</a>
				<a href={`tel:${site.phone.replaceAll(' ', '')}`}>{site.phone}</a>
				<p>{site.location}</p>
			</div>
			<div>
				<p class="eyebrow">{copy.common.social}</p>
				<nav aria-label="Social media">
					{site.socials.map((social) => <a href={social.href} rel="noreferrer">{social.label}</a>)}
				</nav>
			</div>
		</aside>
	</section>
</BaseLayout>

<style>
	.contact-layout {
		display: grid;
		gap: 2rem;
		padding-bottom: clamp(4rem, 8vw, 7rem);
	}

	.contact-form,
	.contact-panel {
		border-top: 1px solid var(--line);
		padding-top: 1rem;
	}

	.contact-form {
		display: grid;
		gap: 1rem;
	}

	label {
		display: grid;
		gap: 0.45rem;
	}

	label span {
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	input,
	select,
	textarea {
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 0;
		background: #0b0b0b;
		color: #fff;
		font: inherit;
		padding: 0.9rem;
	}

	textarea {
		resize: vertical;
	}

	.contact-form .button {
		width: fit-content;
	}

	.contact-panel {
		display: grid;
		align-content: start;
		gap: 2rem;
	}

	.contact-panel div,
	.contact-panel nav {
		display: grid;
		gap: 0.7rem;
	}

	.contact-panel a,
	.contact-panel p:not(.eyebrow) {
		color: var(--muted);
	}

	@media (min-width: 780px) {
		.contact-layout {
			grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
		}
	}
</style>
