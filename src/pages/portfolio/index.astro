---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getCopy, getProjectText } from '../../lib/copy';
import { imageSrc, pathWithBase } from '../../lib/site';

const projects = (await getCollection('portfolio')).sort((a, b) => b.data.year - a.data.year);
const copy = getCopy('en');
const categories = [...new Set(projects.map((project) => project.data.category))];
const categoryAnchors = Object.fromEntries(
	categories.map((category) => [category, projects.find((project) => project.data.category === category)?.id]),
);
const breadcrumbs = [
	{ name: copy.common.home, url: '/' },
	{ name: copy.portfolio.title, url: '/portfolio/' },
];
---

<BaseLayout
	title={copy.portfolio.title}
	description={copy.portfolio.description}
	canonical="/portfolio/"
	breadcrumbs={breadcrumbs}
>
	<Breadcrumbs items={breadcrumbs} />
	<PageIntro eyebrow={copy.portfolio.eyebrow} title={copy.portfolio.heading} text={copy.portfolio.text} />

	<section class="container filters" aria-label={copy.portfolio.categoriesLabel}>
		<a href="#all">{copy.common.all}</a>
		{categories.map((category) => <a href={`#${categoryAnchors[category]}`}>{copy.categories[category]}</a>)}
	</section>

	<section id="all" class="container masonry" aria-label={copy.portfolio.galleryLabel}>
		{
			projects.map((project, index) => (
				<a class="masonry-item" id={project.id} href={pathWithBase(`/portfolio/${project.id}/`)}>
					<img
						src={imageSrc(project.data.cover.src)}
						width={project.data.cover.width}
						height={project.data.cover.height}
						alt={project.data.cover.alt}
						loading={index < 2 ? 'eager' : 'lazy'}
						decoding="async"
					/>
					<span>
						<strong>{getProjectText(project.id, 'en').title}</strong>
						<small>{copy.categories[project.data.category]} / {project.data.year}</small>
					</span>
				</a>
			))
		}
	</section>
</BaseLayout>

<style>
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}

	.filters a {
		border: 1px solid var(--line);
		padding: 0.7rem 0.9rem;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.masonry {
		columns: 1;
		column-gap: 1rem;
		padding-bottom: clamp(4rem, 8vw, 7rem);
	}

	.masonry-item {
		position: relative;
		display: block;
		overflow: hidden;
		margin-bottom: 1rem;
		background: var(--surface);
		break-inside: avoid;
	}

	.masonry-item img {
		width: 100%;
		height: auto;
		transition: transform 500ms ease;
	}

	.masonry-item span {
		position: absolute;
		inset: auto 0 0;
		display: grid;
		gap: 0.25rem;
		padding: 1rem;
		background: linear-gradient(0deg, rgba(0, 0, 0, 0.86), transparent);
	}

	.masonry-item small {
		color: var(--muted);
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.masonry-item:hover img {
		transform: scale(1.035);
	}

	@media (min-width: 680px) {
		.masonry {
			columns: 2;
		}
	}

	@media (min-width: 1020px) {
		.masonry {
			columns: 3;
		}
	}
</style>
