---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ContactBand from '../components/ContactBand.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCopy } from '../lib/copy';
import { imageCatalog, pathWithBase, site } from '../lib/site';

const categoryOrder = ['afterglow', 'atmosphere', 'human', 'monochrome'];
const projects = (await getCollection('portfolio'))
	.sort((a, b) => categoryOrder.indexOf(a.data.category) - categoryOrder.indexOf(b.data.category))
	.slice(0, 3);
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const copy = getCopy('en');

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: site.name,
	url: site.url + site.base,
	description: copy.home.description,
	inLanguage: 'en',
};
---

<BaseLayout title={copy.home.title} description={copy.home.description} image={imageCatalog.hero.src} structuredData={structuredData}>
	<section class="hero" aria-label="Introduction">
		<img
			src={imageCatalog.hero.src}
			width={imageCatalog.hero.width}
			height={imageCatalog.hero.height}
			alt={imageCatalog.hero.alt}
			sizes="100vw"
			fetchpriority="high"
			decoding="async"
		/>
		<div class="hero-content">
			<p class="eyebrow">{copy.home.eyebrow}</p>
			<h1>{copy.home.heading}</h1>
			<p class="lead">{copy.home.intro}</p>
			<div class="button-row">
				<a class="button" href={pathWithBase('/portfolio/')}>{copy.home.portfolioCta}</a>
				<a class="button secondary" href={pathWithBase('/contact/')}>{copy.home.contactCta}</a>
			</div>
		</div>
	</section>

	<section class="section container">
		<SectionHeader eyebrow={copy.home.featuredEyebrow} title={copy.home.featuredTitle} text={copy.home.featuredText} />
		<div class="featured-grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<section class="section container split-feature">
		<div>
			<p class="eyebrow">{copy.home.approachEyebrow}</p>
			<h2>{copy.home.approachTitle}</h2>
		</div>
		<div class="prose">
			<p>{copy.home.approachText}</p>
		</div>
	</section>

	<section class="section container">
		<SectionHeader eyebrow={copy.home.journalEyebrow} title={copy.home.journalTitle} text={copy.home.journalText} />
		<div class="blog-grid">
			{posts.map((post) => <BlogCard post={post} />)}
		</div>
	</section>

	<ContactBand />
</BaseLayout>

<style>
	.hero {
		position: relative;
		min-height: 100svh;
		display: grid;
		align-items: end;
		overflow: hidden;
		padding: 7rem 1rem 3rem;
	}

	.hero::after {
		position: absolute;
		inset: 0;
		content: '';
		background:
			linear-gradient(90deg, rgba(0, 0, 0, 0.84), rgba(0, 0, 0, 0.28) 58%, rgba(0, 0, 0, 0.68)),
			linear-gradient(0deg, #050505, transparent 35%);
	}

	.hero > img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1.25rem;
		width: min(100%, var(--max));
		margin-inline: auto;
		animation: rise 700ms ease both;
	}

	.featured-grid,
	.blog-grid {
		display: grid;
		gap: 1.25rem;
	}

	.split-feature {
		border-block: 1px solid var(--line);
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(18px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (min-width: 780px) {
		.hero {
			padding-inline: 2rem;
		}

		.hero-content {
			padding-bottom: 5vh;
		}

		.featured-grid {
			grid-template-columns: 1.2fr 0.8fr 1fr;
			align-items: start;
		}

		.blog-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.split-feature {
			grid-template-columns: 0.9fr 1.1fr;
			display: grid;
			gap: 2rem;
		}
	}
</style>
