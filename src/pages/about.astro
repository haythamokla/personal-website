---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactBand from '../components/ContactBand.astro';
import PageIntro from '../components/PageIntro.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCopy } from '../lib/copy';
import { imageCatalog } from '../lib/site';

const copy = getCopy('en');
const breadcrumbs = [
	{ name: copy.common.home, url: '/' },
	{ name: copy.about.title, url: '/about/' },
];

const equipment = ['Full-frame mirrorless bodies', 'Fast prime lenses', 'Compact travel zoom', 'Portable LED lighting', 'Color-managed editing workflow'];
const skills = ['Editorial direction', 'Portrait lighting', 'Travel storytelling', 'Commercial still life', 'Post-production', 'Brand image systems'];
const languages = ['English', 'Dutch', 'Arabic', 'Turkish'];
---

<BaseLayout
	title={copy.about.title}
	description={copy.about.description}
	canonical="/about/"
	breadcrumbs={breadcrumbs}
>
	<Breadcrumbs items={breadcrumbs} />
	<PageIntro eyebrow={copy.about.eyebrow} title={copy.about.heading} text={copy.about.text} />

	<section class="container about-grid">
		<div class="image-frame">
			<img src={imageCatalog.studio.src} width={imageCatalog.studio.width} height={imageCatalog.studio.height} alt={imageCatalog.studio.alt} loading="eager" decoding="async" />
		</div>
		<div class="prose">
			<h2>{copy.about.storyTitle}</h2>
			{copy.about.story.map((paragraph) => <p>{paragraph}</p>)}
		</div>
	</section>

	<section class="section container">
		<SectionHeader eyebrow={copy.about.journeyEyebrow} title={copy.about.journeyTitle} text={copy.about.journeyText} />
		<div class="timeline">
			{copy.about.timeline.map((item, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h3>{item[0]}</h3><p class="muted">{item[1]}</p></article>)}
		</div>
	</section>

	<section class="section container lists">
		<div>
			<p class="eyebrow">{copy.about.equipment}</p>
			<ul>{equipment.map((item) => <li>{item}</li>)}</ul>
		</div>
		<div>
			<p class="eyebrow">{copy.about.skills}</p>
			<ul>{skills.map((item) => <li>{item}</li>)}</ul>
		</div>
		<div>
			<p class="eyebrow">{copy.about.languages}</p>
			<ul>{languages.map((item) => <li>{item}</li>)}</ul>
		</div>
	</section>

	<ContactBand />
</BaseLayout>

<style>
	.about-grid {
		display: grid;
		gap: 2rem;
		padding-bottom: clamp(3rem, 7vw, 6rem);
	}

	.about-grid .image-frame {
		aspect-ratio: 4 / 5;
	}

	.timeline,
	.lists {
		display: grid;
		gap: 1rem;
	}

	.timeline article,
	.lists > div {
		border-top: 1px solid var(--line);
		padding-top: 1rem;
	}

	.timeline span {
		color: var(--soft);
		font-weight: 800;
		letter-spacing: 0.12em;
	}

	.timeline h3 {
		margin: 0.75rem 0;
	}

	ul {
		display: grid;
		gap: 0.7rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
		color: var(--muted);
	}

	li {
		border-bottom: 1px solid var(--line);
		padding-bottom: 0.7rem;
	}

	@media (min-width: 780px) {
		.about-grid {
			grid-template-columns: 0.8fr 1fr;
			align-items: center;
		}

		.timeline,
		.lists {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
